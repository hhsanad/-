<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>حاسبة القرض الاحترافية</title>
    <style>
        * { box-sizing: border-box; -webkit-tap-highlight-color: transparent; }
        body { font-family: -apple-system, system-ui, sans-serif; background-color: #f2f2f7; display: flex; justify-content: center; padding-top: 30px; margin: 0; min-height: 100vh; }
        .app-container { background: white; width: 92%; max-width: 400px; padding: 25px; border-radius: 20px; box-shadow: 0 10px 30px rgba(0,0,0,0.08); height: fit-content; }
        h2 { text-align: center; color: #1c1c1e; margin-bottom: 25px; }
        .field { margin-bottom: 15px; }
        label { display: block; margin-bottom: 8px; font-weight: 600; color: #3a3a3c; }
        input { width: 100%; height: 55px; border: none; background: #f2f2f7; border-radius: 12px; padding: 0 15px; font-size: 20px; color: #1c1c1e; outline: none; transition: 0.3s; }
        input:focus { background: #e5e5ea; border: 2px solid #007aff; }
        .results-box { background: #007aff; color: white; padding: 20px; border-radius: 15px; margin-top: 25px; }
        .result-item { display: flex; justify-content: space-between; margin-bottom: 12px; border-bottom: 1px solid rgba(255,255,255,0.2); padding-bottom: 8px; }
        .value-text { font-weight: bold; font-family: sans-serif; }
    </style>
</head>
<body>

<div class="app-container">
    <h2>حاسبة القرض</h2>
    
    <div class="field">
        <label>المبلغ الأصلي</label>
        <input type="number" id="p" inputmode="decimal" placeholder="0" onkeyup="calc()">
    </div>

    <div class="field">
        <label>نسبة الفائدة (%)</label>
        <input type="number" id="r" inputmode="decimal" placeholder="0" onkeyup="calc()">
    </div>

    <div class="field">
        <label>عدد السنوات</label>
        <input type="number" id="y" inputmode="decimal" placeholder="0" onkeyup="calc()">
    </div>

    <div class="results-box">
        <div class="result-item">
            <span>إجمالي الفائدة:</span>
            <span class="value-text" id="ri">0</span>
        </div>
        <div class="result-item">
            <span>المبلغ الكلي:</span>
            <span class="value-text" id="rt">0</span>
        </div>
        <div class="result-item" style="border:none; margin-top:10px; background:rgba(255,255,255,0.1); padding:10px; border-radius:10px;">
            <span>القسط الشهري:</span>
            <span class="value-text" id="rm">0</span>
        </div>
    </div>
</div>

<script>
/* المحرك الحسابي مشفر للحماية */
function calc(){let e=parseFloat(document.getElementById("p").value)||0,t=parseFloat(document.getElementById("r").value)||0,n=parseFloat(document.getElementById("y").value)||0;if(e>0&&n>0){const a=e*(t/100)*n,o=e+a,l=o/(12*n);document.getElementById("ri").innerText=a.toLocaleString(),document.getElementById("rt").innerText=o.toLocaleString(),document.getElementById("rm").innerText=l.toLocaleString(undefined,{minimumFractionDigits:2,maximumFractionDigits:2})}else{document.getElementById("ri").innerText="0",document.getElementById("rt").innerText="0",document.getElementById("rm").innerText="0"}}
</script>

</body>
</html>
